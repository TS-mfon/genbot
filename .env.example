# GenBot - GenLayer Telegram Bot
# Copy to .env and fill in your values

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# --- GenLayer Networks ---
# Default: studionet (https://studio.genlayer.com/api)
# Other option: testnet-bradbury (https://rpc-testnet.genlayer.com)
GENLAYER_RPC_URL=https://studio.genlayer.com/api
GENLAYER_DEFAULT_NETWORK=studionet

# --- Claude (for /audit and /ask fallback) ---
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Wallet Encryption ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WALLET_ENCRYPTION_KEY=

# --- Database ---
DATABASE_PATH=./data/genbot.db

# --- Render ---
PORT=10000
